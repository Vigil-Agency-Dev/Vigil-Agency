# Cairn agent-cairn runtime env
# Copy to .env on VPS (/home/vigil/services/agent-cairn/.env) and fill in secrets.
# Secrets are NEVER in the repo.

# ---- Telegram (MTProto userbot) ----
# Credentials from https://my.telegram.org/apps — one-time registration per Telegram account.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Phone number Cairn's user account is registered to (+countrycode format)
TELEGRAM_PHONE=
# Persisted session string lives here after first-auth. Keep file mode 0600.
TELEGRAM_SESSION_FILE=/home/vigil/services/agent-cairn/state/cairn.session

# ---- Initial channel subscriptions (comma-separated @handles, no @) ----
# Cairn joins these on startup. Idempotent (already-joined is a no-op).
INITIAL_CHANNEL_HANDLES=

# ---- Home channel for heartbeat echoes and directive acks ----
# Optional. Accepts numeric ID (-100xxxxxxxxx) or @handle.
# Recommend a private channel with only DIRECTOR and Cairn as members.
HOME_CHANNEL=

# ---- DIRECTOR's Telegram user ID ----
# Used to resolve bare DMs (no callsign) to DIRECTOR. Set after first auth.
DIRECTOR_TG_USER_ID=

# ---- VIGIL API / Dead-drop ----
VPS_API_BASE=https://ops.jr8ch.com
VIGIL_API_KEY=

# ---- Anthropic ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=2048

# ---- Operational tuning ----
DAILY_SOFT_CAP_USD=10
ITERATION_CAP_PER_DIRECTIVE=10
DEAD_DROP_POLL_INTERVAL_MS=1800000
ANALYST_SYNTHESIS_INTERVAL_MS=7200000
OBSERVATION_BUFFER_LIMIT=200

# ---- Logging + status ----
LOG_DIR=/home/vigil/services/agent-cairn/logs
# Status file — vigil-api reads this for /api/mission/agents lastActivity.
CAIRN_STATUS_FILE=/home/vigil/.openclaw/workspace/dead-drop/team-reports/cairn-status.json
