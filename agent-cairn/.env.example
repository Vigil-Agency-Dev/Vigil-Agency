# CAIRN agent-cairn runtime env
# Copy to .env on VPS (/home/vigil/services/agent-cairn/.env) and fill in secrets.
# Secrets are NEVER in the repo.

# ---- Discord ----
# Bot token from Discord Developer Portal. Provisioned via SSH stdin flow.
CAIRN_DISCORD_TOKEN=
# The Watch guild ID
CAIRN_GUILD_ID=1489279266393952316
# Primary ops channel ID (#cairn-ops) — must be created in The Watch first
CAIRN_OPS_CHANNEL=
# Fallback: ops channel name if ID lookup fails
CAIRN_OPS_CHANNEL_NAME=cairn-ops

# ---- VIGIL API / Dead-drop ----
VPS_API_BASE=https://ops.jr8ch.com
VIGIL_API_KEY=

# ---- Anthropic ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=2048

# ---- Operational tuning ----
DAILY_SOFT_CAP_USD=10
ITERATION_CAP_PER_DIRECTIVE=10
DEAD_DROP_POLL_INTERVAL_MS=1800000
ENGAGEMENT_CYCLE_INTERVAL_MS=1800000
ANALYST_SYNTHESIS_INTERVAL_MS=7200000
OBSERVATION_BUFFER_LIMIT=200

# ---- Logging + status ----
LOG_DIR=/home/vigil/services/agent-cairn/logs
# Team-report status file — vigil-api reads this for /api/mission/agents lastActivity.
# Matches server.mjs line 351: 'cairn': ['cairn-status.json']
CAIRN_STATUS_FILE=/home/vigil/.openclaw/workspace/dead-drop/team-reports/cairn-status.json
